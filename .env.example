# OpenAI (required for coach chat; optional for Garmin-only API)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram — do NOT set on API-only deploys (Coolify). Only for:
#   docker compose --profile telegram up -d
# TELEGRAM_BOT_TOKEN=

# Database Configuration (required for docker compose — used by db + app services)
DB_USER=coach
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=coach_db
DB_PORT=5432
# Optional: full URL (app builds from DB_* if empty)
DATABASE_URL=

# Security Configuration
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=your_44_character_fernet_key_here

# API Configuration (for bot to communicate with API)
API_URL=http://app:8000
WEBAPP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://coach.peleman.io
# Local dev only (docker-compose.dev.yml): host port for FastAPI
# APP_HOST_PORT=8000

# Webapp build + gateway (browser calls API on same domain)
NEXT_PUBLIC_API_URL=https://coach.peleman.io

# Garmin Configuration (Optional - for future commercial use)
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret
GARMIN_REDIRECT_URI=
